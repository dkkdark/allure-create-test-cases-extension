{
    "manifest_version": 3,
    "name": "Allure Create Test Extension",
    "version": "1.0",
    "description": "Adds input field in Allure to create tests via local server",
    "permissions": ["activeTab", "scripting"],
    "content_scripts": [
      {
        "matches": [""],
        "js": ["config.js", "content.js"],
        "css": ["style.css"]
      }
    ]
  }
  